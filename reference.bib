  issn         = {0008-5472},
  doi          = {10.1158/0008-5472.CAN-05-2191},
  abstract     = {High-temperature cooked meat contains heterocyclic amines, including 2-amino-1-methyl-6-phenylimidazo[4,5-b]pyridine (PhIP), and polycyclic aromatic hydrocarbons, such as benzo(a)pyrene (BaP). In rodents, a high intake of PhIP induces prostate tumors. We prospectively investigated the association between meat and meat mutagens, specifically PhIP, and prostate cancer risk in the Prostate, Lung, Colorectal, and Ovarian Cancer Screening Trial. Diet was assessed using a 137-item food frequency questionnaire and a detailed meat-cooking questionnaire linked to a database for BaP and the heterocyclic amines 2-amino-3,8-dimethylimidazo[4,5-b]quinoxaline (MeIQx), 2-amino-3,4,8-trimethylimidazo[4,5-f]quinoxaline (DiMeIQx), and PhIP. During follow-up, we ascertained a total of 1,338 prostate cancer cases among 29,361 men; of these, 868 were incident cases (diagnosed after the first year of follow-up) and 520 were advanced cases (stage III or IV or a Gleason score of {$>$} or =7). Total, red, or white meat intake was not associated with prostate cancer risk. More than 10 g/d of very well done meat, compared with no consumption, was associated with a 1.4-fold increased risk of prostate cancer [95\% confidence interval (95\% CI), 1.05-1.92] and a 1.7-fold increased risk (95\% CI, 1.19-2.40) of incident disease. Although there was no association with MeIQx and DiMeIQx, the highest quintile of PhIP was associated with a 1.2-fold increased risk of prostate cancer (95\% CI, 1.01-1.48) and a 1.3-fold increased risk of incident disease (95\% CI, 1.01-1.61). In conclusion, very well done meat was positively associated with prostate cancer risk. In addition, this study lends epidemiologic support to the animal studies, which have implicated PhIP as a prostate carcinogen.},
  language     = {en},
  keywords     = {/unread,Aged,Benzo(a)pyrene,Cooking,Diet,Humans,Imidazoles,Male,Meat,Middle Aged,Mutagens,Prospective Studies,Prostatic Neoplasms,Quinoxalines,Risk Factors,Surveys and Questionnaires},
  annotation   = {titleTranslation: 肉类及其诱变物与前列腺癌风险的前瞻性研究\\
                  abstractTranslation: 高温烹饪的肉类含有杂环胺，包括2-氨基-1-甲基-6-苯基咪唑[4,5-b]吡啶（PhIP）和多环芳烃，如苯并[a]芘（BaP）。在啮齿动物中，高摄入量的PhIP会导致前列腺肿瘤。我们前瞻性地研究了肉类及肉类诱变剂（特别是PhIP）与前列腺癌风险之间的关联，在前列腺、肺、大肠和卵巢癌筛查试验中进行。饮食评估使用了一份包含137项食物频率的问卷和一份详细的肉类烹饪问卷，后者与包含BaP及杂环胺2-氨基-3,8-二甲基咪唑[4,5-b]喹啉（MeIQx）、2-氨基-3,4,8-三甲基咪唑[4,5-f]喹啉（DiMeIQx）和PhIP的数据库相连接。在随访期间，我们共确认了来自29,361名男性的1,338例前列腺癌病例；其中868例为新发病例（在首次随访后确诊），520例为晚期病例（III或IV期，或者Gleason评分大于或等于7）。总体、红肉或白肉摄入与前列腺癌风险没有关联。每天消费超过10克的全熟肉类与无消费相比，前列腺癌风险增加了1.4倍[95\%置信区间（95\% CI），1.05-1.92]，新发疾病的风险增加了1.7倍（95\% CI，1.19-2.40）。尽管与MeIQx和DiMeIQx没有关联，但PhIP的最高五分位数与前列腺癌风险增加了1.2倍（95\% CI，1.01-1.48）和新发疾病风险增加了1.3倍（95\% CI，1.01-1.61）相关。总之，全熟肉类与前列腺癌风险呈正相关。此外，这项研究为动物研究提供了流行病学支持，动物研究已将PhIP作为前列腺致癌物。\\
                  TLDR: Very well done meat was positively associated with prostate cancer risk in the Prostate, Lung, Colorectal, and Ovarian Cancer Screening Trial and lends epidemiologic support to the animal studies, which have implicated PhIP as a prostate carcinogen.},
  file         = {C:\Users\liuli\Zotero\storage\88GMEDUI\Cross 等 - 2005 - A prospective study of meat and meat mutagens and prostate cancer risk.pdf}
}

@article{crumColiphagesHumanUrinary2023,
  title        = {Coliphages of the Human Urinary Microbiota},
  author       = {Crum, Elias and Merchant, Zubia and Ene, Adriana and Miller-Ensminger, Taylor and Johnson, Genevieve and Wolfe, Alan J. and Putonti, Catherine},
  editor       = {Eppinger, Mark},
  date         = {2023-04-13},
  journaltitle = {PLOS One},
  shortjournal = {PLOS One},
  volume       = {18},
  number       = {4},
  pages        = {e0283930},
  issn         = {1932-6203},
  doi          = {10.1371/journal.pone.0283930},
  url          = {https://dx.plos.org/10.1371/journal.pone.0283930},
  urldate      = {2024-11-27},
  abstract     = {Due to its frequent association with urinary tract infections (UTIs),               Escherichia coli               is the best characterized constituent of the urinary microbiota (urobiome). However, uropathogenic               E               .               coli               is just one member of the urobiome. In addition to bacterial constituents, the urobiome of both healthy and symptomatic individuals is home to a diverse population of bacterial viruses (bacteriophages). A prior investigation found that most bacterial species in the urobiome are lysogens, harboring one or more phages integrated into their genome (prophages). Many of these prophages are temperate phages, capable of entering the lytic cycle and thus lysing their bacterial host. This transition from the lysogenic to lytic life cycle can impact the bacterial diversity of the urobiome. While many phages that infect               E               .               coli               (coliphages) have been studied for decades in the laboratory setting, the coliphages within the urobiome have yet to be cataloged. Here, we investigated the diversity of urinary coliphages by first identifying prophages in all publicly available urinary               E               .               coli               genomes. We detected 3,038 intact prophage sequences, representative of 1,542 unique phages. These phages include both novel species as well as species also found within the gut microbiota. Ten temperate phages were isolated from urinary               E               .               coli               strains included in our analysis, and we assessed their ability to infect and lyse urinary               E               .               coli               strains. We also included in these host range assays other urinary coliphages and laboratory coliphages. The temperate phages and other urinary coliphages were successful in lysing urinary               E               .               coli               strains. We also observed that coliphages from non-urinary sources were most efficient in killing urinary               E               .               coli               strains. The two phages, T2 and N4, were capable of lysing 83.5\% (n = 86) of strains isolated from females with UTI symptoms. In conclusion, our study finds a diverse community of coliphages in the urobiome, many of which are predicted to be temperate phages, ten of which were confirmed here. Their ability to infect and lyse urinary               E               .               coli               strains suggests that urinary coliphages may play a role in modulating the               E               .               coli               strain diversity of the urobiome.},
  language     = {en},
  annotation   = {abstractTranslation: 由于经常与尿路感染（UTI）有关，大肠杆菌是泌尿微生物群（urobiome）中特征最明显的成分。然而，尿路致病性大肠杆菌只是尿路微生物群的一个成员。除了细菌成分外，健康人和有症状的人的尿生物群中还存在着多种细菌病毒（噬菌体）。先前的一项调查发现，尿液生物群中的大多数细菌都是溶菌体，它们的基因组中含有一种或多种噬菌体（原噬菌体）。这些噬菌体中有许多是温带噬菌体，能够进入溶菌循环，从而溶解细菌宿主。从溶解性生命周期到溶解性生命周期的转变会影响尿生物群的细菌多样性。虽然许多感染大肠杆菌的噬菌体（大肠杆菌）已在实验室环境中被研究了数十年，但尿液生物群中的大肠杆菌尚未被编目。在这里，我们首先识别了所有公开的尿液大肠杆菌基因组中的原噬菌体，从而研究了尿液大肠杆菌的多样性。我们检测到了 3,038 个完整的噬菌体序列，代表了 1,542 个独特的噬菌体。这些噬菌体既包括新物种，也包括在肠道微生物群中发现的物种。我们从分析中的尿液大肠杆菌菌株中分离出了 10 个温带噬菌体，并评估了它们感染和裂解尿液大肠杆菌菌株的能力。我们还将其他尿液噬菌体和实验室噬菌体纳入了这些宿主范围测定。温带噬菌体和其他尿液噬菌体都能成功裂解尿液中的大肠杆菌菌株。我们还观察到，非泌尿系统来源的大肠杆菌噬菌体在杀死泌尿系统大肠杆菌菌株时效率最高。T2 和 N4 这两种噬菌体能够裂解 83.5\% （n = 86）从有UTI 症状的女性体内分离出来的菌株。总之，我们的研究在尿液生物群中发现了一个多样化的大肠噬菌体群落，其中许多噬菌体被预测为温带噬菌体，有十种在这里得到了证实。它们感染和裂解尿液中大肠杆菌菌株的能力表明，尿液中的大肠噬菌体可能在调节尿液生物群中大肠杆菌菌株多样性方面发挥作用。\\
                  titleTranslation: 人类泌尿微生物群中的噬菌体\\
                  TLDR: A diverse community of coliphages are found in the urobiome, many of which are predicted to be temperate phages, ten of which were confirmed here.},
  file         = {C:\Users\liuli\Zotero\storage\CD5HU5Z3\Crum 等 - 2023 - Coliphages of the human urinary microbiota.pdf}
}

@article{daiAndrogenSignalingProstate2017,
  title        = {Androgen Signaling in Prostate Cancer},
  author       = {Dai, Charles and Heemers, Hannelore and Sharifi, Nima},
  date         = {2017-09-01},
  journaltitle = {Cold Spring Harbor Perspectives in Medicine},
  shortjournal = {Cold Spring Harb. Perspect. Med.},
  volume       = {7},
  number       = {9},
  eprint       = {28389515},
  eprinttype   = {pubmed},
  pages        = {a030452},
  issn         = {2157-1422},
  doi          = {10.1101/cshperspect.a030452},
  abstract     = {The androgen-signaling axis plays a pivotal role in the pathogenesis of prostate cancer. Since the landmark discovery by Huggins and Hodges, gonadal depletion of androgens has remained a mainstay of therapy for advanced disease. However, progression to castration-resistant prostate cancer (CRPC) typically follows and is largely the result of restored androgen signaling. Efforts to understand the mechanisms behind CRPC have revealed new insights into dysregulated androgen signaling and intratumoral androgen synthesis, which has ultimately led to the development of several novel androgen receptor (AR)-directed therapies for CRPC. However, emergence of resistance to these newer agents has also galvanized new directions in investigations of prereceptor and postreceptor AR regulation. Here, we review our current understanding of AR signaling as it pertains to the biology and natural history of prostate cancer.},
  language     = {en},
  pmcid        = {PMC5580512},
  keywords     = {/unread,Animals,Disease Progression,Drug Resistance Neoplasm,Gene Expression Regulation Neoplastic,Humans,Ligands,Male,Molecular Targeted Therapy,Prostatic Neoplasms,Receptors Androgen,Signal Transduction,Transcription Factors,Transcription Genetic},
  annotation   = {titleTranslation: 前列腺癌中的雄激素信号传导\\
                  abstractTranslation: 雄激素信号轴在前列腺癌的发病机制中起着关键作用。自哈金斯和霍奇斯的标志性发现以来，性腺雄激素的去除一直是晚期疾病治疗的主流。然而，通常会进展为去势抵抗性前列腺癌（CRPC），这主要是由于雄激素信号的恢复。研究CRPC背后的机制的努力揭示了对雄激素信号失调和肿瘤内雄激素合成的新见解，最终导致了若干针对CRPC的新型雄激素受体（AR）导向疗法的开发。然而，这些新药出现抗药性也促使了对受体前和受体后AR调控的研究方向的重新关注。在此，我们回顾了当前对AR信号的理解，以及其与前列腺癌生物学和自然历史的关系。\\
                  TLDR: Current understanding of AR signaling as it pertains to the biology and natural history of prostate cancer is reviewed.},
  file         = {C:\Users\liuli\Zotero\storage\4YKDW88S\Dai 等 - 2017 - Androgen signaling in prostate cancer.pdf}
}

@article{debonoProstateCarcinogenesisInflammatory2020,
  title        = {Prostate Carcinogenesis: Inflammatory Storms},
  shorttitle   = {Prostate Carcinogenesis},
  author       = {family=Bono, given=Johann S., prefix=de, useprefix=true and Guo, Christina and Gurel, Bora and De Marzo, Angelo M. and Sfanos, Karen S. and Mani, Ram S. and Gil, Jesús and Drake, Charles G. and Alimonti, Andrea},
  date         = {2020-08},
  journaltitle = {Nature Reviews Cancer},
  shortjournal = {Nat. Rev. Cancer},
  volume       = {20},
  number       = {8},
  pages        = {455--469},
  publisher    = {Nature Publishing Group},
  issn         = {1474-1768},
  doi          = {10.1038/s41568-020-0267-9},
  url          = {https://www.nature.com/articles/s41568-020-0267-9},
  urldate      = {2026-02-09},
  abstract     = {Prostate cancer is a major cause of cancer morbidity and mortality. Intra-prostatic inflammation is a risk factor for prostate carcinogenesis, with diet, chemical injury and an altered microbiome being causally implicated. Intra-prostatic inflammatory cell recruitment and expansion can ultimately promote DNA double-strand breaks and androgen receptor activation in prostate epithelial cells. The activation of the senescence-associated secretory phenotype fuels further ‘inflammatory storms’, with free radicals leading to further DNA damage. This drives the overexpression of DNA repair and tumour suppressor genes, rendering these genes susceptible to mutagenic insults, with carcinogenesis accelerated by germline DNA repair gene defects. We provide updates on recent advances in elucidating prostate carcinogenesis and explore novel therapeutic and prevention strategies harnessing these discoveries.},
  language     = {en},
  keywords     = {/unread,Cancer microenvironment,DNA damage response,Inflammation,Prostate cancer},
  annotation   = {TLDR: This Review discusses intra-prostatic inflammatory processes and how they are induced and perpetuated, thereby driving prostate cancer development and progression and provides insight into potential preventative and therapeutic strategies.},
  file         = {C:\Users\liuli\Zotero\storage\CPJ6XSBT\de Bono 等 - 2020 - Prostate carcinogenesis inflammatory storms.pdf}
}

@article{dejeaPatientsFamilialAdenomatous2018,
  title        = {Patients with Familial Adenomatous Polyposis Harbor Colonic Biofilms Containing Tumorigenic Bacteria},
  author       = {Dejea, Christine M. and Fathi, Payam and Craig, John M. and Boleij, Annemarie and Taddese, Rahwa and Geis, Abby L. and Wu, Xinqun and DeStefano Shields, Christina E. and Hechenbleikner, Elizabeth M. and Huso, David L. and Anders, Robert A. and Giardiello, Francis M. and Wick, Elizabeth C. and Wang, Hao and Wu, Shaoguang and Pardoll, Drew M. and Housseau, Franck and Sears, Cynthia L.},
  date         = {2018-02-02},
  journaltitle = {Science},
  shortjournal = {Science},
  volume       = {359},
  number       = {6375},
  pages        = {592--597},
  publisher    = {American Association for the Advancement of Science},
  doi          = {10.1126/science.aah3648},
  url          = {https://www.science.org/doi/abs/10.1126/science.aah3648},
  urldate      = {2024-12-04},
  abstract     = {Individuals with sporadic colorectal cancer (CRC) frequently harbor abnormalities in the composition of the gut microbiome; however, the microbiota associated with precancerous lesions in hereditary CRC remains largely unknown. We studied colonic mucosa of patients with familial adenomatous polyposis (FAP), who develop benign precursor lesions (polyps) early in life. We identified patchy bacterial biofilms composed predominately of Escherichia coli and Bacteroides fragilis. Genes for colibactin (clbB) and Bacteroides fragilis toxin (bft), encoding secreted oncotoxins, were highly enriched in FAP patients’ colonic mucosa compared to healthy individuals. Tumor-prone mice cocolonized with E. coli (expressing colibactin), and enterotoxigenic B. fragilis showed increased interleukin-17 in the colon and DNA damage in colonic epithelium with faster tumor onset and greater mortality, compared to mice with either bacterial strain alone. These data suggest an unexpected link between early neoplasia of the colon and tumorigenic bacteria.},
  language     = {en},
  keywords     = {/unread},
  annotation   = {titleTranslation: 家族性腺瘤性息肉病患者携带含有肿瘤致病菌的结肠生物膜。\\
                  abstractTranslation: 具有散发性结直肠癌（CRC）的人往往拥有肠道微生物组组成的异常；然而，遗传性CRC中与癌前病变相关的微生物群仍然 largely 不为人知。我们研究了家族性腺瘤性息肉病（FAP）患者的结肠黏膜，这些患者在生命早期会发展出良性前驱病变（息肉）。我们发现由大肠杆菌和脆弱性梭菌主要组成的局部细菌生物膜。与健康个体相比，FAP患者的结肠黏膜中与分泌性肿瘤毒素相关的肠毒素基因（clbB和bft）高度富集。与表现出肠毒素的大肠杆菌（表达肠毒素的）和肠致病性脆弱性梭菌共同定殖的肿瘤易感小鼠，表现出结肠中白细胞介素-17的增加以及结肠上皮的DNA损伤，肿瘤发生更快且死亡率更高，相较于单独感染任一细菌株的小鼠。这些数据表明结肠早期新生物与肿瘤细菌之间存在意想不到的联系。\\
                  TLDR: Genes for colibactin and Bacteroides fragilis toxin, encoding secreted oncotoxins, were highly enriched in FAP patients’ colonic mucosa compared to healthy individuals, suggesting an unexpected link between early neoplasia of the colon and tumorigenic bacteria.},
  file         = {C:\Users\liuli\Zotero\storage\ARKYSDXN\Dejea 等 - 2018 - Patients with familial adenomatous polyposis harbor colonic biofilms containing tumorigenic bacteria.pdf}
}

@article{demarzoInflammationProstateCarcinogenesis2007,
  title        = {Inflammation in Prostate Carcinogenesis},
  author       = {De Marzo, Angelo M. and Platz, Elizabeth A. and Sutcliffe, Siobhan and Xu, Jianfeng and Grönberg, Henrik and Drake, Charles G. and Nakai, Yasutomo and Isaacs, William B. and Nelson, William G.},
  date         = {2007-04},
  journaltitle = {Nature Reviews. Cancer},
  shortjournal = {Nat. Rev. Cancer},
  volume       = {7},
  number       = {4},
  eprint       = {17384581},
  eprinttype   = {pubmed},
  pages        = {256--269},
  issn         = {1474-175X},
  doi          = {10.1038/nrc2090},
  abstract     = {About 20\% of all human cancers are caused by chronic infection or chronic inflammatory states. Recently, a new hypothesis has been proposed for prostate carcinogenesis. It proposes that exposure to environmental factors such as infectious agents and dietary carcinogens, and hormonal imbalances lead to injury of the prostate and to the development of chronic inflammation and regenerative 'risk factor' lesions, referred to as proliferative inflammatory atrophy (PIA). By developing new experimental animal models coupled with classical epidemiological studies, genetic epidemiological studies and molecular pathological approaches, we should be able to determine whether prostate cancer is driven by inflammation, and if so, to develop new strategies to prevent the disease.},
  language     = {en},
  pmcid        = {PMC3552388},
  keywords     = {/unread,Carcinogens,Chromosome Aberrations,Chronic Disease,Diet,Epigenesis Genetic,Humans,Infections,Inflammation,Male,Models Biological,Mutation,Prostatic Neoplasms,Prostatitis,Risk Factors},
  annotation   = {abstractTranslation: 大约20\%的所有人类癌症是由慢性感染或慢性炎症状态引起的。最近，提出了一种新的前列腺致癌假说。该假说提出，接触感染性因子和饮食致癌物等环境因素以及内分泌失调会导致前列腺受损，进而发展为慢性炎症和再生性“风险因素”病变，这些病变被称为增生性炎症萎缩（PIA）。通过开发新的实验动物模型，并结合经典流行病学研究、遗传流行病学研究和分子病理学方法，我们应该能够确定前列腺癌是否由炎症驱动，如果是的话，制定新的预防该疾病的策略。\\
                  titleTranslation: 前列腺癌发生过程中的炎症\\
                  TLDR: Whether prostate cancer is driven by inflammation, and if so, to develop new strategies to prevent the disease, is determined by developing new experimental animal models coupled with classical Epidemiological studies, genetic epidemiological studies and molecular pathological approaches.},
  file         = {C:\Users\liuli\Zotero\storage\8457M57H\De Marzo 等 - 2007 - Inflammation in prostate carcinogenesis.pdf}
}

@article{dennisAdenomatousPolypsAre2013,
  title        = {Adenomatous Polyps Are Driven by Microbe-Instigated Focal Inflammation and Are Controlled by {{IL-10-producing T}} Cells},
  author       = {Dennis, Kristen L. and Wang, Yunwei and Blatner, Nichole R. and Wang, Shuya and Saadalla, Abdulrahman and Trudeau, Erin and Roers, Axel and Weaver, Casey T. and Lee, James J. and Gilbert, Jack A. and Chang, Eugene B. and Khazaie, Khashayarsha},
  date         = {2013-10-01},
  journaltitle = {Cancer Research},
  shortjournal = {Cancer Res},
  volume       = {73},
  number       = {19},
  eprint       = {23955389},
  eprinttype   = {pubmed},
  pages        = {5905--5913},
  issn         = {1538-7445},
  doi          = {10.1158/0008-5472.CAN-13-1511},
  abstract     = {Interleukin (IL)-10 is elevated in cancer and is thought to contribute to immune tolerance and tumor growth. Defying these expectations, the adoptive transfer of IL-10-expressing T cells to mice with polyposis attenuates microbial-induced inflammation and suppresses polyposis. To gain better insights into how IL-10 impacts polyposis, we genetically ablated IL-10 in T cells in APC(Δ468) mice and compared the effects of treatment with broad-spectrum antibiotics. We found that T cells and regulatory T cells (Treg) were a major cellular source of IL-10 in both the healthy and polyp-bearing colon. Notably, T cell-specific ablation of IL-10 produced pathologies that were identical to mice with a systemic deficiency in IL-10, in both cases increasing the numbers and growth of colon polyps. Eosinophils were found to densely infiltrate colon polyps, which were enriched similarly for microbiota associated previously with colon cancer. In mice receiving broad-spectrum antibiotics, we observed reductions in microbiota, inflammation, and polyposis. Together, our findings establish that colon polyposis is driven by high densities of microbes that accumulate within polyps and trigger local inflammatory responses. Inflammation, local microbe densities, and polyp growth are suppressed by IL-10 derived specifically from T cells and Tregs.},
  language     = {en-US},
  pmcid        = {PMC4322779},
  keywords     = {Adenomatous Polyps,Adoptive Transfer,Animals,Anti-Bacterial Agents,CD4-Positive T-Lymphocytes,Colon,Colonic Neoplasms,Cytokines,Disease Models Animal,DNA Bacterial,Fluorescent Antibody Technique,Immune Tolerance,Inflammation,Interleukin-10,Mice,Mice Inbred C57BL,Mice Knockout,Microbiota,Real-Time Polymerase Chain Reaction,Reverse Transcriptase Polymerase Chain Reaction,RNA Messenger,T-Lymphocytes Regulatory},
  annotation   = {TLDR: It is established that colon polyposis is driven by high densities of microbes that accumulate within polyps and trigger local inflammatory responses, which are suppressed by IL-10 derived specifically from T cells and Tregs.\\
                  titleTranslation: 腺瘤性息肉是由微生物引发的局部炎症驱动的，并受到产生IL-10的T细胞的控制。},
  file         = {C:\Users\liuli\Zotero\storage\FGI3YNJP\Dennis 等 - 2013 - Adenomatous polyps are driven by microbe-instigated focal inflammation and are controlled by IL-10-p.pdf}
}

