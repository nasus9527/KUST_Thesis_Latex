@article{yuAkkermansiaMuciniphilaMetabolite2024,
  title        = {Akkermansia Muciniphila {{Metabolite Inosine Inhibits Castration Resistance}} in {{Prostate Cancer}}},
  author       = {Yu, Yao and Li, Leqian and Yang, Qishen and Xue, Jingwen and Wang, Benlin and Xie, Ming and Shangguan, Wentai and Zhu, Zhangrui and Wu, Peng},
  date         = {2024-08-12},
  journaltitle = {Microorganisms},
  shortjournal = {Microorganisms},
  volume       = {12},
  number       = {8},
  eprint       = {39203495},
  eprinttype   = {pubmed},
  pages        = {1653},
  issn         = {2076-2607},
  doi          = {10.3390/microorganisms12081653},
  abstract     = {Prostate cancer (PCa) is initially sensitive to androgen deprivation therapy (ADT) but ultimately develops resistance and progresses to castration-resistant prostate cancer (CRPC) with a poor prognosis. This study indicated that some PCa patients and mice were more sensitive to ADT and entered CRPC later, which was related to the gut microbiota, especially the enrichment of Akkermansia muciniphila (AKK). Untargeted metabolomics analysis found that serum inosine level was upregulated in the treatment-sensitive group and significantly correlated with AKK. Furthermore, we revealed that intestinal permeability and serum lipopolysaccharide (LPS) levels increased in treatment-resistant mice. LPS stimulated the upregulation of p-NF-κB p65 and AR in tumors. Supplementing AKK metabolite inosine could alleviate intestinal barrier damage and reduce serum LPS level, ultimately inhibiting castration resistance via the LPS/NF-κB/AR axis. Finally, we constructed a predictive model for CRPC combining gut microbiota and clinical information (AUC = 0.729). This study revealed the potential mechanism of gut microbiota on CRPC and provided potential therapeutic targets and prognostic indicators.},
  language     = {eng},
  pmcid        = {PMC11356635},
  keywords     = {Akkermansia muciniphila,androgen deprivation therapy,castration-resistant prostate cancer,gut microbiota,inosine},
  annotation   = {TLDR: This study revealed the potential mechanism of gut microbiota on CRPC and provided potential therapeutic targets and prognostic indicators and constructed a predictive model for CRPC combining gut microbiota and clinical information.},
  file         = {C:\Users\liuli\Zotero\storage\4L766HZF\Yu 等 - 2024 - Akkermansia muciniphila Metabolite Inosine Inhibits Castration Resistance in Prostate Cancer.pdf}
}

@article{zhaoTolllikeReceptorsProstate2014,
  title        = {Toll-like Receptors and Prostate Cancer},
  author       = {Zhao, Shu and Zhang, Yifan and Zhang, Qingyuan and Wang, Fen and Zhang, Dekai},
  date         = {2014},
  journaltitle = {Frontiers in Immunology},
  shortjournal = {Front Immunol},
  volume       = {5},
  eprint       = {25101092},
  eprinttype   = {pubmed},
  pages        = {352},
  issn         = {1664-3224},
  doi          = {10.3389/fimmu.2014.00352},
  abstract     = {Prostate cancer is the second leading cause of cancer-related death in men after lung cancer. Immune responses clearly play a critical role in the tumorigenesis and in the efficacy of radiation therapy and chemotherapy in prostate cancer; however, the underlying molecular mechanisms are still poorly understood. Toll-like receptors (TLRs) are a well-known family of pattern recognition receptors that play a key role in host immune system. Recent studies demonstrate that there are links between TLRs and cancer; however, the function and biological importance of TLRs in prostate cancer seems complex. To elucidate the role of TLRs and innate immunity in prostate cancer might provide us with a better understanding of the molecular mechanisms of this disease. Moreover, utilizing the agonists or antagonists of TLRs might represent a promising new strategy against prostate cancer. In this review, we summarize recent advances on the studies of association between TLR signaling and prostate cancer, TLR polymorphisms and prostate cancer risk, and provide some insights about TLRs as potential targets for prostate cancer immunotherapy.},
  language     = {en-US},
  pmcid        = {PMC4107957},
  keywords     = {immunotherapy,innate immunity,prostate cancer,TLR signaling,toll-like receptor},
  annotation   = {TLDR: To elucidate the role of TLRs and innate immunity in prostate cancer might provide a better understanding of the molecular mechanisms of this disease, and utilizing the agonists or antagonists ofTLRs might represent a promising new strategy against prostate cancer.\\
                  titleTranslation: 类 Toll 受体与前列腺癌},
  file         = {C:\Users\liuli\Zotero\storage\M4EDX4BG\Zhao 等 - 2014 - Toll-like receptors and prostate cancer.pdf}
}

@article{zhengPhageguidedModulationGut2019,
  title        = {Phage-Guided Modulation of the Gut Microbiota of Mouse Models of Colorectal Cancer Augments Their Responses to Chemotherapy},
  author       = {Zheng, Di-Wei and Dong, Xue and Pan, Pei and Chen, Ke-Wei and Fan, Jin-Xuan and Cheng, Si-Xue and Zhang, Xian-Zheng},
  date         = {2019-09},
  journaltitle = {Nature Biomedical Engineering},
  shortjournal = {Nat. Biomed. Eng.},
  volume       = {3},
  number       = {9},
  pages        = {717--728},
  publisher    = {Nature Publishing Group},
  issn         = {2157-846X},
  doi          = {10.1038/s41551-019-0423-2},
  url          = {https://www.nature.com/articles/s41551-019-0423-2},
  urldate      = {2024-12-07},
  abstract     = {The microbiota in the human gut is strongly correlated with the progression of colorectal cancer (CRC) and with therapeutic responses to CRC. Here, by leveraging the higher concentration of the pro-tumoural Fusobacterium nucleatum and the absence of antineoplastic butyrate-producing bacteria in the faecal microbiota of patients with CRC, we show that—in mice with orthotopic colorectal tumours or with spontaneously formed colorectal tumours—oral or intravenous administration of irinotecan-loaded dextran nanoparticles covalently linked to azide-modified phages that inhibit the growth of F. nucleatum significantly augments the efficiency of first-line chemotherapy treatments of CRC. We also show that oral administration of the phage-guided irinotecan-loaded nanoparticles in piglets led to negligible changes in haemocyte counts, immunoglobulin and histamine levels, and liver and renal functions. Phage-guided nanotechnology for the modulation of the gut microbiota might inspire new approaches for the treatment of CRC.},
  language     = {en},
  keywords     = {/unread,Biomaterials,Cancer therapy},
  annotation   = {TLDR: Dextran nanoparticles loaded with a chemotherapeutic agent and bound to phages that eliminate a pro-tumoural gut bacterium and promote the growth of anticancer-compound-producing bacteria boost chemotherapy responses in mouse models of colorectal cancer.\\
                  abstractTranslation: 人类肠道中的微生物群与结直肠癌（CRC）的进展以及对 CRC 的治疗反应密切相关。 在这里，我们利用 CRC 患者粪便微生物群中较高浓度的促肿瘤生长的核酸镰刀菌和抗肿瘤丁酸菌的缺失，证明了在患有正位结直肠肿瘤或自发形成的结直肠肿瘤的小鼠中，口服或静脉注射与抑制核酸镰刀菌生长的叠氮修饰噬菌体共价连接的右旋糖酐纳米颗粒，可显著提高结直肠癌一线化疗的效率。 我们还发现，通过口服或静脉注射与抑制核酸噬菌体生长的叠氮修饰噬菌体共价连接的右旋糖酐纳米颗粒，可明显提高 CRC 一线化疗的疗效。 我们的研究还表明，小猪口服噬菌体引导的伊立替康负载纳米颗粒后，血细胞计数、免疫球蛋白和组胺水平以及肝肾功能的变化微乎其微。 噬菌体引导的纳米技术用于调节肠道微生物群，可能会为治疗 CRC 带来新的灵感。\\
                  titleTranslation: 噬菌体引导下调节结直肠癌小鼠模型的肠道菌群可增强其化疗反应},
  file         = {C:\Users\liuli\Zotero\storage\XM77Y4UM\Zheng 等 - 2019 - Phage-guided modulation of the gut microbiota of mouse models of colorectal cancer augments their re.pdf}
}

@article{zhengReportCancerEpidemiology2019,
  title        = {[Report of Cancer Epidemiology in {{China}}, 2015]},
  author       = {Zheng, R. S. and Sun, K. X. and Zhang, S. W. and Zeng, H. M. and Zou, X. N. and Chen, R. and Gu, X. Y. and Wei, W. W. and He, J.},
  date         = {2019-01-23},
  journaltitle = {Zhonghua Zhong Liu Za Zhi [Chinese Journal of Oncology]},
  shortjournal = {Zhonghua Zhong Liu Za Zhi [Chinese J. Oncol.},
