}

@article{gaoCooccurrenceNetworksReveal2022,
  title        = {Co-Occurrence Networks Reveal More Complexity than Community Composition in Resistance and Resilience of Microbial Communities},
  author       = {Gao, Cheng and Xu, Ling and Montoya, Liliam and Madera, Mary and Hollingsworth, Joy and Chen, Liang and Purdom, Elizabeth and Singan, Vasanth and Vogel, John and Hutmacher, Robert B. and Dahlberg, Jeffery A. and Coleman-Derr, Devin and Lemaux, Peggy G. and Taylor, John W.},
  date         = {2022-07-05},
  journaltitle = {Nature Communications},
  shortjournal = {Nat. Commun.},
  volume       = {13},
  number       = {1},
  pages        = {3867},
  publisher    = {Nature Publishing Group},
  issn         = {2041-1723},
  doi          = {10.1038/s41467-022-31343-y},
  url          = {https://www.nature.com/articles/s41467-022-31343-y},
  urldate      = {2026-02-09},
  abstract     = {Plant response to drought stress involves fungi and bacteria that live on and in plants and in the rhizosphere, yet the stability of these myco- and micro-biomes remains poorly understood. We investigate the resistance and resilience of fungi and bacteria to drought in an agricultural system using both community composition and microbial associations. Here we show that tests of the fundamental hypotheses that fungi, as compared to bacteria, are (i) more resistant to drought stress but (ii) less resilient when rewetting relieves the stress, found robust support at the level of community composition. Results were more complex using all-correlations and co-occurrence networks. In general, drought disrupts microbial networks based on significant positive correlations among bacteria, among fungi, and between bacteria and fungi. Surprisingly, co-occurrence networks among functional guilds of rhizosphere fungi and leaf bacteria were strengthened by drought, and the same was seen for networks involving arbuscular mycorrhizal fungi in the rhizosphere. We also found support for the stress gradient hypothesis because drought increased the relative frequency of positive correlations.},
  language     = {en},
  keywords     = {Microbial ecology},
  annotation   = {TLDR: Tests of the fundamental hypotheses that fungi are more resistant to drought stress but less resilient when rewetting relieves the stress found robust support at the level of community composition are shown.},
  file         = {C:\Users\liuli\Zotero\storage\UZHSHZL3\Gao 等 - 2022 - Co-occurrence networks reveal more complexity than community composition in resistance and resilienc.pdf}
}

@article{gaoMetabolicFitnessDeterminants2017,
  title        = {Metabolic and Fitness Determinants for in Vitro Growth and Intestinal Colonization of the Bacterial Pathogen Campylobacter Jejuni},
  author       = {Gao, Beile and Vorwerk, Hanne and Huber, Claudia and Lara-Tejero, Maria and Mohr, Juliane and Goodman, Andrew L. and Eisenreich, Wolfgang and Galán, Jorge E. and Hofreuter, Dirk},
  date         = {2017-05-19},
  journaltitle = {PLOS Biology},
  shortjournal = {PLOS Biol.},
  volume       = {15},
  number       = {5},
  pages        = {e2001390},
  publisher    = {Public Library of Science},
