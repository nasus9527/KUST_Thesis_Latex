@article{eelesGeneticEpidemiologyProstate2014,
  title        = {The Genetic Epidemiology of Prostate Cancer and Its Clinical Implications},
  author       = {Eeles, Rosalind and Goh, Chee and Castro, Elena and Bancroft, Elizabeth and Guy, Michelle and Al Olama, Ali Amin and Easton, Douglas and Kote-Jarai, Zsofia},
  date         = {2014-01},
  journaltitle = {Nature Reviews. Urology},
  shortjournal = {Nat. Rev., Urol.},
  volume       = {11},
  number       = {1},
  eprint       = {24296704},
  eprinttype   = {pubmed},
  pages        = {18--31},
  issn         = {1759-4820},
  doi          = {10.1038/nrurol.2013.266},
  abstract     = {Worldwide, familial and epidemiological studies have generated considerable evidence of an inherited component to prostate cancer. Indeed, rare highly penetrant genetic mutations have been implicated. Genome-wide association studies (GWAS) have also identified 76 susceptibility loci associated with prostate cancer risk, which occur commonly but are of low penetrance. However, these mutations interact multiplicatively, which can result in substantially increased risk. Currently, approximately 30\% of the familial risk is due to such variants. Evaluating the functional aspects of these variants would contribute to our understanding of prostate cancer aetiology and would enable population risk stratification for screening. Furthermore, understanding the genetic risks of prostate cancer might inform predictions of treatment responses and toxicities, with the goal of personalized therapy. However, risk modelling and clinical translational research are needed before we can translate risk profiles generated from these variants into use in the clinical setting for targeted screening and treatment.},
  language     = {en},
  keywords     = {/unread,Genetic Predisposition to Disease,Genome-Wide Association Study,Global Health,Humans,Male,Molecular Epidemiology,Morbidity,Prostatic Neoplasms},
  annotation   = {abstractTranslation: 在全球范围内，家庭和流行病学研究已经产生了大量关于前列腺癌遗传成分的证据。实际上，罕见的高渗透性遗传突变已被涉及。全基因组关联研究（GWAS）还确定了76个与前列腺癌风险相关的易感位点，这些位点在一般人群中常见，但渗透性较低。然而，这些突变是相互作用的，这可能导致风险显著增加。目前，大约30\%的家族风险是由于这些变异造成的。评估这些变异的功能特性将有助于我们理解前列腺癌的病因，并将使人群风险分层筛查成为可能。此外，了解前列腺癌的遗传风险可能会为治疗反应和毒性的预测提供依据，旨在实现个性化治疗。然而，在我们能够将这些变异生成的风险谱转换为临床环境中用于靶向筛查和治疗之前，需要进行风险建模和临床转化研究。\\
                  titleTranslation: 前列腺癌的遗传流行病学及其临床意义\\
                  TLDR: Evaluating the functional aspects of rare highly penetrant genetic mutations associated with prostate cancer risk would contribute to the understanding of prostate cancer aetiology and would enable population risk stratification for screening.}
}

@article{fengMetagenomicMetatranscriptomicAnalysis2019,
  title        = {Metagenomic and Metatranscriptomic Analysis of Human Prostate Microbiota from Patients with Prostate Cancer},
  author       = {Feng, Ye and Ramnarine, Varune Rohan and Bell, Robert and Volik, Stanislav and Davicioni, Elai and Hayes, Vanessa M. and Ren, Shancheng and Collins, Colin C.},
  date         = {2019-12},
  journaltitle = {BMC Genomics},
  shortjournal = {BMC Genomics},
  volume       = {20},
  number       = {1},
  pages        = {146},
  issn         = {1471-2164},
  doi          = {10.1186/s12864-019-5457-z},
  url          = {https://bmcgenomics.biomedcentral.com/articles/10.1186/s12864-019-5457-z},
  urldate      = {2024-11-29},
  abstract     = {Background: Prostate cancer (PCa) is the most common malignant neoplasm among men in many countries. Since most precancerous and cancerous tissues show signs of inflammation, chronic bacterial prostatitis has been hypothesized to be a possible etiology. However, establishing a causal relationship between microbial inflammation and PCa requires a comprehensive analysis of the prostate microbiome. The aim of this study was to characterize the microbiome in prostate tissue of PCa patients and investigate its association with tumour clinical characteristics as well as host expression profiles. Results: The metagenome and metatranscriptome of tumour and the adjacent benign tissues were assessed in 65 Chinese radical prostatectomy specimens. Escherichia, Propionibacterium, Acinetobacter and Pseudomonas were abundant in both metagenome and metatranscriptome, thus constituting the core of the prostate microbiome. The biodiversity of the microbiomes could not be differentiated between the matched tumour/benign specimens or between the tumour specimens of low and high Gleason Scores. The expression profile of ten Pseudomonas genes was strongly correlated with that of eight host small RNA genes; three of the RNA genes may negatively associate with metastasis. Few viruses could be identified from the prostate microbiomes. Conclusions: This is the first study of the human prostate microbiome employing an integrated metagenomics and metatranscriptomics approach. In this Chinese cohort, both metagenome and metatranscriptome analyses showed a non-sterile microenvironment in the prostate of PCa patients, but we did not find links between the microbiome and local progression of PCa. However, the correlated expression of Pseudomonas genes and human small RNA genes may provide tantalizing preliminary evidence that Pseudomonas infection may impede metastasis.},
  language     = {en},
  keywords     = {/unread},
  annotation   = {titleTranslation: 前列腺癌患者前列腺微生物群的元基因组和元转录组分析\\
                  TLDR: This first study of the human prostate microbiome employing an integrated metagenomics and metatranscriptomics approach showed a non-sterile microenvironment in the prostate of PCa patients, but it did not find links between the microbiome and local progression ofPCa.},
  file         = {C:\Users\liuli\Zotero\storage\9DPKW39I\Feng 等 - 2019 - Metagenomic and metatranscriptomic analysis of human prostate microbiota from patients with prostate.pdf}
}

