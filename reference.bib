@article{caoIntratumouralMicrobiotaNew2024,
  title        = {Intratumoural Microbiota: A New Frontier in Cancer Development and Therapy},
  shorttitle   = {Intratumoural Microbiota},
  author       = {Cao, Yaqi and Xia, Hui and Tan, Xueyun and Shi, Chunwei and Ma, Yanling and Meng, Daquan and Zhou, Mengmeng and Lv, Zhilei and Wang, Sufei and Jin, Yang},
  date         = {2024-01-10},
  journaltitle = {Signal Transduction and Targeted Therapy},
  shortjournal = {Sig Transduct Target Ther},
  volume       = {9},
  number       = {1},
  pages        = {15},
  issn         = {2059-3635},
  doi          = {10.1038/s41392-023-01693-0},
  url          = {https://www.nature.com/articles/s41392-023-01693-0},
  urldate      = {2024-11-25},
  abstract     = {Abstract             Human microorganisms, including bacteria, fungi, and viruses, play key roles in several physiological and pathological processes. Some studies discovered that tumour tissues once considered sterile actually host a variety of microorganisms, which have been confirmed to be closely related to oncogenesis. The concept of intratumoural microbiota was subsequently proposed. Microbiota could colonise tumour tissues through mucosal destruction, adjacent tissue migration, and hematogenic invasion and affect the biological behaviour of tumours as an important part of the tumour microenvironment. Mechanistic studies have demonstrated that intratumoural microbiota potentially promote the initiation and progression of tumours by inducing genomic instability and mutations, affecting epigenetic modifications, promoting inflammation response, avoiding immune destruction, regulating metabolism, and activating invasion and metastasis. Since more comprehensive and profound insights about intratumoral microbiota are continuously emerging, new methods for the early diagnosis and prognostic assessment of cancer patients have been under examination. In addition, interventions based on intratumoural microbiota show great potential to open a new chapter in antitumour therapy, especially immunotherapy, although there are some inevitable challenges. Here, we aim to provide an extensive review of the concept, development history, potential sources, heterogeneity, and carcinogenic mechanisms of intratumoural microorganisms, explore the potential role of microorganisms in tumour prognosis, and discuss current antitumour treatment regimens that target intratumoural microorganisms and the research prospects and limitations in this field.},
  language     = {en},
  keywords     = {Carcinogenesis,Cell Transformation Neoplastic,Humans,Immunotherapy,Microbiota,Neoplasms,Tumor Microenvironment},
  annotation   = {titleTranslation: 肿瘤内微生物群：癌症发展和治疗的新领域\\
                  abstractTranslation: 摘要 包括细菌、真菌和病毒在内的人类微生物在多个生理和病理过程中发挥着关键作用。一些研究发现，曾被认为是无菌的肿瘤组织实际上寄生着多种微生物，这些微生物已被证实与肿瘤发生密切相关。随后，人们提出了肿瘤内微生物群的概念。微生物群可通过粘膜破坏、邻近组织迁移和血源性侵袭等途径定植于肿瘤组织，并作为肿瘤微环境的重要组成部分影响肿瘤的生物学行为。机理研究表明，瘤内微生物群可能通过诱导基因组不稳定性和突变、影响表观遗传修饰、促进炎症反应、避免免疫破坏、调节新陈代谢以及激活侵袭和转移来促进肿瘤的发生和发展。由于人们对肿瘤内微生物群不断有更全面、更深刻的认识，用于癌症患者早期诊断和预后评估的新方法也在研究之中。此外，尽管存在一些不可避免的挑战，但基于瘤内微生物群的干预措施显示出巨大的潜力，可为抗肿瘤疗法，尤其是免疫疗法揭开新的篇章。在此，我们旨在广泛综述瘤内微生物的概念、发展历史、潜在来源、异质性和致癌机制，探讨微生物在肿瘤预后中的潜在作用，并讨论目前针对瘤内微生物的抗肿瘤治疗方案以及该领域的研究前景和局限性。\\
                  TLDR: An extensive review of the concept, development history, potential sources, heterogeneity, and carcinogenic mechanisms of intratumoural microorganisms, explore the potential role of microorganisms in tumour prognosis, and discuss current antitumour treatment regimens that target intratumoural microorganisms are provided.},
  file         = {C:\Users\liuli\Zotero\storage\2J38TBQL\Cao 等 - 2024 - Intratumoural microbiota a new frontier in cancer development and therapy.pdf}
}

@article{caoUniquePhospholipidomeEnteric2020,
  title        = {The Unique Phospholipidome of the Enteric Pathogen {{{\mkbibemph{Campylobacter}}}}{\mkbibemph{ Jejuni}}: Lysophosholipids Are Required for Motility at Low Oxygen Availability},
  shorttitle   = {The Unique Phospholipidome of the Enteric Pathogen {{{\mkbibemph{Campylobacter}}}}{\mkbibemph{ Jejuni}}},
  author       = {Cao, Xuefeng and Brouwers, Jos F. H. M. and family=Dijk, given=Linda, prefix=van, useprefix=true and family=Lest, given=Chris H. A., prefix=van de, useprefix=true and Parker, Craig T. and Huynh, Steven and family=Putten, given=Jos P. M., prefix=van, useprefix=true and Kelly, David J. and Wösten, Marc M. S. M.},
  date         = {2020-09-04},
  journaltitle = {Journal of Molecular Biology},
  shortjournal = {J. Mol. Biol.},
  volume       = {432},
  number       = {19},
  pages        = {5244--5258},
  issn         = {0022-2836},
  doi          = {10.1016/j.jmb.2020.07.012},
  url          = {https://www.sciencedirect.com/science/article/pii/S0022283620304599},
  urldate      = {2026-02-09},
  abstract     = {In response to changes in their environment bacteria need to change both their protein and phospholipid repertoire to match environmental requirements, but the dynamics of bacterial phospholipid composition under different growth conditions is still largely unknown. In the present study, we investigated the phospholipidome of the bacterial pathogen Campylobacter jejuni. Transcription profiling on logarithmic and stationary phase grown cells of the microaerophilic human pathogen C. jejuni using RNA-seq revealed differential expression of putative phospholipid biosynthesis genes. By applying high-performance liquid chromatography tandem–mass spectrometry, we identified 203 phospholipid species representing the first determination of the phospholipidome of this pathogen. We identified nine different phospholipid classes carrying between one and three acyl chains. Phospholipidome analysis on bacteria of different ages (0–5\,days) showed rapid changes in the ratio of phospholipids containing ethanolamine, or glycerol as phospholipid head group and in the number of cyclopropane bond containing fatty acids. Oxygen concentration influenced the percentage of lysophospholipids, and cyclo-propane bonds containing acyl chains. We show that large amounts of the phospholipids are lysophospholipids (30–45\%), which mutant studies reveal are needed for normal C. jejuni motility at low oxygen conditions. C. jejuni possesses an unusual phospholipidome that is highly dynamic in response to environmental changes.},
  language     = {en},
  keywords     = {Cfa,lysophospholipids,phospholipidome,PldA},
  annotation   = {TLDR: It is shown that large amounts of the phospholipidids are lysophospholipids, which mutant studies reveal are needed for normal C. jejuni motility at low oxygen conditions.},
  file         = {C\:\\Users\\liuli\\Zotero\\storage\\M6X8DGU3\\Cao 等 - 2020 - The unique phospholipidome of the enteric pathogen Campylobacter jejuni lysophosholipids are.pdf;C\:\\Users\\liuli\\Zotero\\storage\\YQU5BMKQ\\S0022283620304599.html}
}

@article{cardoniCooccurrenceNetworkAnalysis2023,
  title        = {Co-Occurrence Network Analysis Unveils the Actual Differential Impact on the Olive Root Microbiota by Two Verticillium Wilt Biocontrol Rhizobacteria},
  author       = {Cardoni, Martina and Fernández-González, Antonio J. and Valverde-Corredor, Antonio and Fernández-López, Manuel and Mercado-Blanco, Jesús},
  date         = {2023-03-22},
  journaltitle = {Environmental Microbiome},
  shortjournal = {Environ. Microbiome},
  volume       = {18},
  number       = {1},
  pages        = {21},
  issn         = {2524-6372},
  doi          = {10.1186/s40793-023-00480-2},
  url          = {https://doi.org/10.1186/s40793-023-00480-2},
  urldate      = {2026-02-09},
  abstract     = {Verticillium wilt of olive (VWO), caused by Verticillium dahliae Kleb, is one of the most threatening diseases affecting olive cultivation. An integrated disease management strategy is recommended for the effective control of VWO. Within this framework, the use of biological control agents (BCAs) is a sustainable and environmentally friendly approach. No studies are available on the impact that the introduction of BCAs has on the resident microbiota of olive roots. Pseudomonas simiae PICF7 and Paenibacillus polymyxa PIC73 are two BCAs effective against VWO. We examined the effects of the introduction of these BCAs on the structure, composition and co-occurrence networks of the olive (cv. Picual) root-associated microbial communities. The consequences of the subsequent inoculation with V. dahliae on BCA-treated plants were also assessed.},
  language     = {en},
  keywords     = {Biological control agents,Network topology,Olea europaea,Paenibacillus polymyxa,Pseudomonas simiae,Root microbial community,Verticillium dahliae},
  annotation   = {TLDR: The absence of significant modifications on the structure and composition of the ‘Picual’ belowground microbiota due to the introduction of the tested BCAs underlines the low/null environmental impact of these rhizobacteria.},
  file         = {C:\Users\liuli\Zotero\storage\L5RPBA52\Cardoni 等 - 2023 - Co-occurrence network analysis unveils the actual differential impact on the olive root microbiota b.pdf}
}

@article{cavarrettaMicrobiomeProstateTumor2017,
  title        = {The {{Microbiome}} of the {{Prostate Tumor Microenvironment}}},
  author       = {Cavarretta, Ilaria and Ferrarese, Roberto and Cazzaniga, Walter and Saita, Diego and Lucianò, Roberta and Ceresola, Elisa R. and Locatelli, Irene and Visconti, Laura and Lavorgna, Giovanni and Briganti, Alberto and Nebuloni, Manuela and Doglioni, Claudio and Clementi, Massimo and Montorsi, Francesco and Canducci, Filippo and Salonia, Andrea},
  date         = {2017-10},
  journaltitle = {European Urology},
  shortjournal = {European Urology},
  volume       = {72},
  number       = {4},
  pages        = {625--631},
  issn         = {03022838},
  doi          = {10.1016/j.eururo.2017.03.029},
  url          = {https://linkinghub.elsevier.com/retrieve/pii/S0302283817302506},
  urldate      = {2024-11-29},
  abstract     = {Background: The advent of molecular-based methods of identification and characterization of complex microbial populations has led to a new era of microbial discovery. A detailed and comprehensive analysis of the microbial ecosystem of the pathologic and healthy prostate tissues has not been yet reported. Objectives: To characterize the microbiome possibly associated to the pathologic prostate microenvironment. Design, setting, and participants: The microbiome profile of tumor, peri-tumor, and nontumor tissues was assessed on 16 radical prostatectomy-specimens. Outcome measurements and statistical analysis: Microbiome analysis was assessed by massive ultradeep pyrosequencing. Bacteria load was expressed as a percentage of the total number of bacteria. The statistical significance of differences among specimengroups was tested with Friedman’s test (Dunn posthoc test) and Wilcoxon rank-sum test. Results and limitations: Three phyla, six classes, nine orders, 14 families, and 11 genera were above the set threshold value of 1\%, respectively. Significant differences in specific microbial populations among tumor/peri-tumor and nontumor prostate specimens were observed at certain taxonomic levels. Among genera, Propionibacterium spp. were the most abundant. Staphylococcus spp. were more represented in the tumor/ peri-tumor tissues (p {$<$} 0.05). The restricted number of specimens represents a potential limitation. Conclusions: The prostate contains a plethora of bacteria, which set themselves within the gland with a distribution dependent on the nature of the tissue, thus suggesting a possible pathophysiological correlation between the composition of the local microbial niche and the presence of the tumor itself. Future studies will help to clarify the role of these specific bacteria and their potential to be exploited as new biomarkers.},
  language     = {en},
  keywords     = {/unread},
  annotation   = {titleTranslation: 前列腺肿瘤微环境的微生物组\\
                  TLDR: The prostate contains a plethora of bacteria, which set themselves within the gland with a distribution dependent on the nature of the tissue, thus suggesting a possible pathophysiological correlation between the composition of the local microbial niche and the presence of the tumor itself.},
  file         = {C:\Users\liuli\Zotero\storage\79Z9G4PP\Cavarretta 等 - 2017 - The Microbiome of the Prostate Tumor Microenvironment.pdf}
}

@article{chandrasekarMechanismsResistanceCastrationresistant2015,
  title        = {Mechanisms of Resistance in Castration-Resistant Prostate Cancer ({{CRPC}})},
  author       = {Chandrasekar, Thenappan and Yang, Joy C. and Gao, Allen C. and Evans, Christopher P.},
  date         = {2015-06},
  journaltitle = {Translational Andrology and Urology},
  shortjournal = {Transl. Androl. Urol.},
  volume       = {4},
  number       = {3},
  eprint       = {26814148},
  eprinttype   = {pubmed},
  pages        = {365--380},
  issn         = {2223-4691},
  doi          = {10.3978/j.issn.2223-4683.2015.05.02},
  url          = {https://www.ncbi.nlm.nih.gov/pmc/articles/PMC4708226/},
  urldate      = {2025-02-14},
  abstract     = {Despite advances in prostate cancer diagnosis and management, morbidity from prostate cancer remains high. Approximately 20\% of men present with advanced or metastatic disease, while 29,000 men continue to die of prostate cancer each year. Androgen deprivation therapy (ADT) has been the standard of care for initial management of advanced or metastatic prostate cancer since Huggins and Hodges first introduced the concept of androgen-dependence in 1972, but progression to castration-resistant prostate cancer (CRPC) occurs within 2-3 years of initiation of ADT. CRPC, previously defined as hormone-refractory prostate cancer, is now understood to still be androgen dependent. Multiple mechanisms of resistance help contribute to the progression to castration resistant disease, and the androgen receptor (AR) remains an important driver in this progression. These mechanisms include AR amplification and hypersensitivity, AR mutations leading to promiscuity, mutations in coactivators/corepressors, androgen-independent AR activation, and intratumoral and alternative androgen production. More recently, identification of AR variants (ARVs) has been established as another mechanism of progression to CRPC. Docetaxel chemotherapy has historically been the first-line treatment for CRPC, but in recent years, newer agents have been introduced that target some of these mechanisms of resistance, thereby providing additional survival benefit. These include AR signaling inhibitors such as enzalutamide (Xtandi, ENZA, MDV-3100) and CYP17A1 inhibitors such as abiraterone acetate (Zytiga). Ultimately, these agents will also fail to suppress CRPC. While some of the mechanisms by which these agents fail are unique, many share similarities to the mechanisms contributing to CRPC progression. Understanding these mechanisms of resistance to ADT and currently approved CRPC treatments will help guide future research into targeted therapies.},
  language     = {en},
  pmcid        = {PMC4708226},
  annotation   = {TLDR: Multiple mechanisms of resistance to ADT and currently approved CRPC treatments will help guide future research into targeted therapies, and some of the mechanisms by which these agents fail are unique, many share similarities to the mechanisms contributing to CRPC progression.\\
                  titleTranslation: 去势抵抗型前列腺癌（CRPC）的抗药机制},
  file         = {C:\Users\liuli\Zotero\storage\BKVF6W65\Chandrasekar 等 - 2015 - Mechanisms of resistance in castration-resistant prostate cancer (CRPC).pdf}
}

