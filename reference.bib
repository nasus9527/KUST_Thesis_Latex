@article{maekawaMolecularMechanismsProstate2024,
  title        = {Molecular Mechanisms of Prostate Cancer Development in the Precision Medicine Era: A Comprehensive Review},
  shorttitle   = {Molecular Mechanisms of Prostate Cancer Development in the Precision Medicine Era},
  author       = {Maekawa, Shigekatsu and Takata, Ryo and Obara, Wataru},
  date         = {2024-01-25},
  journaltitle = {Cancers},
  shortjournal = {Cancers},
  volume       = {16},
