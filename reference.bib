@article{vandeguchteAlternativeStableStates2020,
  title        = {Alternative Stable States in the Intestinal Ecosystem: Proof of Concept in a Rat Model and a Perspective of Therapeutic Implications},
  shorttitle   = {Alternative Stable States in the Intestinal Ecosystem},
  author       = {Van de Guchte, Maarten and Burz, Sebastian D. and Cadiou, Julie and Wu, Jiangbo and Mondot, Stanislas and Blottière, Hervé M. and Doré, Joël},
  date         = {2020-11-06},
  journaltitle = {Microbiome},
  shortjournal = {Microbiome},
  volume       = {8},
  number       = {1},
  pages        = {153},
  issn         = {2049-2618},
  doi          = {10.1186/s40168-020-00933-7},
  url          = {https://doi.org/10.1186/s40168-020-00933-7},
  urldate      = {2026-02-07},
  abstract     = {Chronic immune-mediated diseases are rapidly expanding and notoriously difficult to cure. Altered relatively stable intestinal microbiota configurations are associated with several of these diseases, and with a possible pre-disease condition (more susceptible to disease development) of the host-microbiota ecosystem. These observations are reminiscent of the behavior of an ecosystem with alternative stable states (different stable configurations that can exist under identical external conditions), and we recently postulated that health, pre-disease and disease represent such alternative states. Here, our aim was to examine if alternative stable states indeed exist in the intestinal ecosystem.},
  language     = {en},
  keywords     = {Alternative stable states,Cure,GI tract,Host,Inflammation,Interaction,Intestinal ecosystem,Microbiota,Symbiosis,Therapy},
  annotation   = {TLDR: This work provides proof of concept showing the existence of alternative stable states in the rat intestinal ecosystem and proposes a conceptual model providing new insights in the interplay between host inflammatory status and microbiota status, which will support innovative diagnosis, therapeutic strategy, and monitoring in the treatment of chronic inflammatory conditions.},
