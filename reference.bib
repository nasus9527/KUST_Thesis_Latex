}

@article{neugentAdvancesUnderstandingHuman2020,
  title        = {Advances in Understanding the Human Urinary Microbiome and Its Potential Role in Urinary Tract Infection},
  author       = {Neugent, Michael L. and Hulyalkar, Neha V. and Nguyen, Vivian H. and Zimmern, Philippe E. and De Nisco, Nicole J.},
  editor       = {Garsin, Danielle A.},
  date         = {2020-04-28},
  journaltitle = {Mbio},
  shortjournal = {Mbio},
  volume       = {11},
  number       = {2},
  pages        = {e00218-20},
  issn         = {2161-2129, 2150-7511},
  doi          = {10.1128/mBio.00218-20},
  url          = {https://journals.asm.org/doi/10.1128/mBio.00218-20},
  urldate      = {2024-11-27},
  abstract     = {Recent advances in the analysis of microbial communities colonizing the human body have identified a resident microbial community in the human urinary tract (UT). Compared to many other microbial niches, the human UT harbors a relatively low biomass. Studies have identified many genera and species that may constitute a core urinary microbiome. However, the contribution of the UT microbiome to urinary tract infection (UTI) and recurrent UTI (rUTI) pathobiology is not yet clearly understood. Evidence suggests that commensal species within the UT and urogenital tract (UGT) microbiomes, such as Lactobacillus crispatus, may act to protect against colonization with uropathogens. However, the mechanisms and fundamental biology of the urinary microbiome-host relationship are not understood. The ability to measure and characterize the urinary microbiome has been enabled through the development of next-generation sequencing and bioinformatic platforms that allow for the unbiased detection of resident microbial DNA. Translating technological advances into clinical insight will require further study of the microbial and genomic ecology of the urinary microbiome in both health and disease. Future diagnostic, prognostic, and therapeutic options for the management of UTI may soon incorporate efforts to measure, restore, and/or preserve the native, healthy ecology of the urinary microbiomes.},
  issue        = {2},
  language     = {en},
  annotation   = {abstractTranslation: 最近，对人体定植微生物群落的分析取得了进展，发现了人体泌尿道（UT）中的常驻微生物群落。与许多其他微生物栖息地相比，人体UT的生物量相对较低。研究发现了许多可能构成核心泌尿微生物群的菌属和菌种。然而，UT 微生物组对尿路感染（UTI）和复发性UTI（rUTI）病理生物学的贡献尚不清楚。有证据表明，UT 和泌尿生殖道 (UGT) 微生物组中的共生物种（如脆片乳杆菌）可起到防止泌尿病原体定植的作用。然而，泌尿微生物组与宿主关系的机制和基本生物学原理尚不清楚。下一代测序和生物信息学平台的发展使测量和描述泌尿微生物组的能力得以提高，这些平台可对常驻微生物 DNA 进行无偏见的检测。要将技术进步转化为临床洞察力，就需要进一步研究泌尿微生物组在健康和疾病中的微生物和基因组生态学。未来治疗尿路感染的诊断、预后和治疗方案可能很快就会包括测量、恢复和/或保护泌尿微生物组的原生健康生态。\\
                  titleTranslation: 了解人类泌尿微生物组及其在尿路感染中的潜在作用的进展\\
                  TLDR: Future diagnostic, prognostic, and therapeutic options for the management of UTI may soon incorporate efforts to measure, restore, and/or preserve the native, healthy ecology of the urinary microbiomes.},
  file         = {C:\Users\liuli\Zotero\storage\GZCVC24R\Neugent 等 - 2020 - Advances in Understanding the Human Urinary Microbiome and Its Potential Role in Urinary Tract Infec.pdf}
}

@article{neugentUrinaryBiochemicalEcology2025,
  title        = {Urinary Biochemical Ecology Reveals Microbiome-Metabolite Interactions and Metabolic Markers of Recurrent Urinary Tract Infection},
  author       = {Neugent, Michael L. and Hulyalkar, Neha V. and Ghosh, Debasish and Saenz, Ceejay N. and Zimmern, Philippe E. and Shulaev, Vladimir and De Nisco, Nicole J.},
  date         = {2025-11-24},
  journaltitle = {npj Biofilms and Microbiomes},
  shortjournal = {npj Biofilms Microbiomes},
  volume       = {11},
  number       = {1},
  pages        = {216},
  publisher    = {Nature Publishing Group},
  issn         = {2055-5008},
  doi          = {10.1038/s41522-025-00844-1},
  url          = {https://www.nature.com/articles/s41522-025-00844-1},
  urldate      = {2026-02-09},
  abstract     = {Recurrent urinary tract infections (rUTIs) are a major clinical challenge, and their increasing prevalence underscores the need to define host-microbiome interactions underlying susceptibility. How the urinary microbiota engages with the biochemical environment of the urogenital tract is yet to be fully defined. Here, we leverage paired metagenomic and quantitative metabolomic data to establish a microbe-metabolite association network of the female urinary microbiome and define metabolic signatures of rUTI. We observe unique metabolic networks of uropathogens and uroprotective species, highlighting potential metabolite-driven ecological shifts influencing rUTI susceptibility. We find distinct metabolites associated with urinary microbiome diversity and identify a lipid signature of active rUTI that accurately distinguishes our cases from controls. Finally, we identify deoxycholic acid as a prognostic indicator for UTI recurrence. Together, these findings provide insight into microbiome-metabolite interactions within the female urinary tract and highlight potential biomarkers for the development of new diagnostic tools to improve patient outcomes.},
  language     = {en},
  keywords     = {Metagenomics,Microbiome},
  annotation   = {TLDR: Paired metagenomic and quantitative metabolomic data are used to establish a microbe-metabolite association network of the female urinary microbiome and define metabolic signatures of rUTI, and a lipid signature of active rUTI that accurately distinguishes cases from controls is identified.},
  file         = {C:\Users\liuli\Zotero\storage\U4Q8LUYB\Neugent 等 - 2025 - Urinary biochemical ecology reveals microbiome-metabolite interactions and metabolic markers of recu.pdf}
}

@article{nguyenEcologicalInsightsResilience2023,
  title        = {Ecological Insights into the Resilience of Marine Plastisphere throughout a Storm Disturbance},
  author       = {Nguyen, Dzung and Masasa, Matan and Ovadia, Ofer and Guttman, Lior},
  date         = {2023-02-01},
  journaltitle = {Science of the Total Environment},
  shortjournal = {Sci. Total Environ.},
  volume       = {858},
  pages        = {159775},
  issn         = {0048-9697},
  doi          = {10.1016/j.scitotenv.2022.159775},
  url          = {https://www.sciencedirect.com/science/article/pii/S0048969722068759},
  urldate      = {2026-02-09},
  abstract     = {Among numerous research about marine plastisphere, the community living on the surface of plastic debris, little attention was given to the ecological mechanisms governing prokaryotes compared to eukaryotes, and even less focused on their resilience in a changing climate with more storm prevalence. Our current research recruited an integrated approach involving community succession across temporal dimension, ecological mechanisms that govern the assembly, and resilience to environmental perturbations to highlight the ecology of different kingdoms in the plastisphere. Towards this goal, we examined the succession of the prokaryotic and eukaryotic communities on artificial plastic nets in a sidestream of seawater from the Gulf of Aqaba over 35 days. A robust local storm enabled investigation of the alterations before, during, and after this disturbance, aiming at the community's potential to recover. Data from 16S and 18S rRNA sequencing and microscopic analyses decrypted the plastisphere diversity, community assembly, and stochasticity, followed by further analyses of functional and co-occurrence networks for the prokaryotic group. Prokaryotic and eukaryotic communities underwent exact opposite ecological mechanisms. While determinism driven by a robust environmental selection dictated the prokaryotic community assembly, stochasticity prevailed when this condition was relaxed. Interestingly, resilience against disturbance was observed in prokaryotes but not in eukaryotes. The decrease in compositional, functional diversity and network complexity in the prokaryotic community was reversed, presumably due to the niche specification process and high dispersal. Niche specification following perturbation was evident in some bacteria by selected functions associated with plastic degradation, stress response, and antibiotic resistance. On the contrary, eukaryotes decreased in diversity and were dominated by the commonly found Chlorophyta towards the later successional period. Novel findings on the ecology of marine plastisphere during perturbation encourage the integration of this aspect into prediction research.},
  language     = {en},
  keywords     = {Community assembly,Microbial succession,Plastisphere,Resilience,Stochasticity},
  annotation   = {TLDR: This research examined the succession of the prokaryotic and eukaryotic communities on artificial plastic nets in a sidestream of seawater from the Gulf of Aqaba over 35\,days to highlight the ecology of different kingdoms in the plastisphere.\\
                  abstractTranslation: 在众多关于海洋塑料圈（即塑料碎片表面生物群落）的研究中，与真核生物相比，原核生物所遵循的生态机制受到的关注较少，而针对其在风暴频发的气候变化背景下的恢复力研究则更为匮乏。本研究采用了一种综合方法，涵盖时间维度上的群落演替、驱动群落构建的生态机制以及对环境扰动的恢复力，以揭示塑料圈中不同生物界的生态学特征。为此，我们考察了亚喀巴湾海水支流中人工塑料网上原核与真核生物群落在35天内的演替过程。一场强烈的局地风暴使我们得以探究此次扰动前、中、后阶段群落的变化，旨在评估其恢复潜力。通过16S和18S rRNA测序及显微分析数据，我们解析了塑料圈的多样性、群落构建及随机性过程，并进一步对原核生物群进行了功能与共现网络分析。研究发现，原核与真核生物群落遵循截然相反的生态机制：在严格的环境选择驱动下，原核群落构建由确定性过程主导；而当环境选择压力减弱时，随机性过程则占优势。值得注意的是，原核生物表现出对扰动的恢复力，而真核生物则未显现此特性。原核群落的组成多样性、功能多样性及网络复杂性的下降均出现逆转，这很可能得益于生态位特化过程和高扩散能力。扰动后，部分细菌通过选择与塑料降解、胁迫响应和抗生素抗性相关的功能，表现出明显的生态位特化。相反，真核生物多样性下降，并在演替后期被常见的绿藻门生物所主导。本研究关于扰动期间海洋塑料圈生态学的新发现，有助于推动将此类动态纳入预测性研究体系。},
  file         = {C\:\\Users\\liuli\\Zotero\\storage\\7RK46SED\\Nguyen 等 - 2023 - Ecological insights into the resilience of marine plastisphere throughout a storm disturbance.pdf;C\:\\Users\\liuli\\Zotero\\storage\\WFSGGU6Q\\S0048969722068759.html}
}

@article{nguyenInflammationProstateCancer2014,
  title        = {Inflammation and Prostate Cancer: The Role of Interleukin 6 ({{IL-6}})},
  shorttitle   = {Inflammation and Prostate Cancer},
  author       = {Nguyen, Daniel P. and Li, Jinyi and Tewari, Ashutosh K.},
  date         = {2014},
  journaltitle = {BJU International},
  shortjournal = {BJU Int.},
  volume       = {113},
  number       = {6},
  pages        = {986--992},
  issn         = {1464-410X},
  doi          = {10.1111/bju.12452},
  url          = {https://onlinelibrary.wiley.com/doi/abs/10.1111/bju.12452},
  urldate      = {2026-02-09},
  abstract     = {Environmental and genetic aspects are reflected in the development of prostate cancer. In this context, there is growing evidence that chronic inflammation is involved in the regulation of cellular events in prostate carcinogenesis, including disruption of the immune response and regulation of the tumour microenvironment. One of the best surrogates of chronic inflammation in prostate cancer is interleukin 6 (IL-6). Serum IL-6 levels are elevated in patients with untreated metastatic or castration-resistant prostate cancer (CRPC) and correlate negatively with tumour survival and response to chemotherapy. Via multiple signal pathways including the Janus tyrosine family kinase (JAK)-signal transducer and activator of transcription (STAT) pathway, the extracellular signal-regulated kinase 1 and 2 (ERK1/2)-mitogen activated protein kinase (MAPK) pathway, and the phosphoinositide 3-kinase (PI3-K) pathway, IL-6 is able to promote prostate cancer cell proliferation and inhibit apoptosis in vitro and in vivo. IL-6 is associated with aggressive prostate cancer phenotype and may be involved in the metastatic process through regulation of epithelial–mesenchymal transition (EMT) and homing of cancer cells to the bone. A substantial body of evidence suggests that IL-6 plays a major role in the transition from hormone-dependent to CRPC, most notably through accessory activation of the androgen receptor. Collectively, these data have stimulated the development of agents targeting IL-6 signalling pathways. A chimeric anti-IL-6 monoclonal antibody has been tested in clinical trials, with mixed results.},
  language     = {en},
  keywords     = {androgen receptor,inflammation,interleukin-6,metastasis,prostate cancer,tumour growth},
  annotation   = {TLDR: A substantial body of evidence suggests that IL‐6 plays a major role in the transition from hormone‐dependent to CRPC, most notably through accessory activation of the androgen receptor.},
  file         = {C\:\\Users\\liuli\\Zotero\\storage\\QUK494GK\\Nguyen 等 - 2014 - Inflammation and prostate cancer the role of interleukin 6 (IL-6).pdf;C\:\\Users\\liuli\\Zotero\\storage\\HZ8H4MC8\\bju.html}
}

@article{ohaganDoubleStrandBreaks2008,
  title        = {Double Strand Breaks Can Initiate Gene Silencing and {{SIRT1-dependent}} Onset of {{DNA}} Methylation in an Exogenous Promoter {{CpG}} Island},
  author       = {O'Hagan, Heather M. and Mohammad, Helai P. and Baylin, Stephen B.},
  date         = {2008-08-15},
  journaltitle = {PLOS Genetics},
  shortjournal = {PLOS Genet.},
  volume       = {4},
  number       = {8},
  eprint       = {18704159},
  eprinttype   = {pubmed},
  pages        = {e1000155},
  issn         = {1553-7404},
  doi          = {10.1371/journal.pgen.1000155},
  abstract     = {Chronic exposure to inducers of DNA base oxidation and single and double strand breaks contribute to tumorigenesis. In addition to the genetic changes caused by this DNA damage, such tumors often contain epigenetically silenced genes with aberrant promoter region CpG island DNA hypermethylation. We herein explore the relationships between such DNA damage and epigenetic gene silencing using an experimental model in which we induce a defined double strand break in an exogenous promoter construct of the E-cadherin CpG island, which is frequently aberrantly DNA hypermethylated in epithelial cancers. Following the onset of repair of the break, we observe recruitment to the site of damage of key proteins involved in establishing and maintaining transcriptional repression, namely SIRT1, EZH2, DNMT1, and DNMT3B, and the appearance of the silencing histone modifications, hypoacetyl H4K16, H3K9me2 and me3, and H3K27me3. Although in most cells selected after the break, DNA repair occurs faithfully with preservation of activity of the promoter, a small percentage of the plated cells demonstrate induction of heritable silencing. The chromatin around the break site in such a silent clone is enriched for most of the above silent chromatin proteins and histone marks, and the region harbors the appearance of increasing DNA methylation in the CpG island of the promoter. During the acute break, SIRT1 appears to be required for the transient recruitment of DNMT3B and subsequent methylation of the promoter in the silent clones. Taken together, our data suggest that normal repair of a DNA break can occasionally cause heritable silencing of a CpG island-containing promoter by recruitment of proteins involved in silencing. Furthermore, with contribution of the stress-related protein SIRT1, the break can lead to the onset of aberrant CpG island DNA methylation, which is frequently associated with tight gene silencing in cancer.},
  language     = {en},
  pmcid        = {PMC2491723},
  keywords     = {/unread,Cell Line Tumor,Chromatin,CpG Islands,DNA (Cytosine-5-)-Methyltransferases,DNA Breaks Double-Stranded,DNA Methylation,DNA Methyltransferase 3B,Gene Silencing,Humans,Promoter Regions Genetic,Sirtuin 1,Sirtuins},
  annotation   = {titleTranslation: 双链断裂可以启动基因沉默和依赖于SIRT1的外源性启动子CpG岛的DNA甲基化开始。\\
                  TLDR: The data suggest that normal repair of a DNA break can occasionally cause heritable silencing of a CpG island–containing promoter by recruitment of proteins involved in silencing.},
  file         = {C:\Users\liuli\Zotero\storage\FVL5XZ63\O'Hagan 等 - 2008 - Double strand breaks can initiate gene silencing and SIRT1-dependent onset of DNA methylation in an.pdf}
}

