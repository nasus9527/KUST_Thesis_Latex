  author       = {Massari, Francesco and Mollica, Veronica and Di Nunno, Vincenzo and Gatto, Lidia and Santoni, Matteo and Scarpelli, Marina and Cimadamore, Alessia and Lopez-Beltran, Antonio and Cheng, Liang and Battelli, Nicola and Montironi, Rodolfo and Brandi, Giovanni},
