  author       = {O'Hagan, Heather M. and Wang, Wei and Sen, Subhojit and Destefano Shields, Christina and Lee, Stella S. and Zhang, Yang W. and Clements, Eriko G. and Cai, Yi and Van Neste, Leander and Easwaran, Hariharan and Casero, Robert A. and Sears, Cynthia L. and Baylin, Stephen B.},
  date         = {2011-11-15},
