  author       = {Kitamura, Fujiko and Kitamura, Noriko and Mori, Akio and Tatsumi, Hideki and Nemoto, Soichi and Miyoshi, Hiroyuki and Miyatake, Shoichiro and Hiroi, Takachika and Kaminuma, Osamu},
  date         = {2010},
  journaltitle = {International Archives of Allergy and Immunology},
