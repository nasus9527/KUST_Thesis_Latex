  file         = {C:\Users\liuli\Zotero\storage\HID9L6NX\Ritch和Cookson - 2016 - Advances in the management of castration resistant prostate cancer.pdf}
}

@article{rizzoMicrobiotaProstateCancer2022,
  title        = {Microbiota and Prostate Cancer},
  author       = {Rizzo, Alessandro and Santoni, Matteo and Mollica, Veronica and Fiorentino, Michelangelo and Brandi, Giovanni and Massari, Francesco},
  date         = {2022-11},
