@article{whiteDifferentialInflammatoryResponse2015,
  title        = {Differential Inflammatory Response to Helicobacter Pylori Infection: Etiology and Clinical Outcomes},
  shorttitle   = {Differential Inflammatory Response to Helicobacter Pylori Infection},
  author       = {White, Jonathan Richard and Winter, Jody Anne and Robinson, Karen},
  date         = {2015-08-13},
  journaltitle = {Journal of Inflammation Research},
  shortjournal = {J. Inflammation Res.},
  volume       = {8},
  eprint       = {26316793},
  eprinttype   = {pubmed},
  pages        = {137--147},
  publisher    = {Dove Medical Press},
  issn         = {null},
  doi          = {10.2147/JIR.S64888},
  url          = {https://www.tandfonline.com/doi/abs/10.2147/JIR.S64888},
  urldate      = {2024-12-05},
  abstract     = {The bacterial pathogen Helicobacter pylori commonly colonizes the human gastric mucosa during early childhood and persists throughout life. The organism has evolved multiple mechanisms for evading clearance by the immune system and, despite inducing inflammation in the stomach, the majority of infections are asymptomatic. H. pylori is the leading cause of peptic ulcer disease and gastric cancer. However, disease outcomes are related to the pattern and severity of chronic inflammation in the gastric mucosa, which in turn is influenced by both bacterial and host factors. Despite over 2 decades of intensive research, there remains an incomplete understanding of the circumstances leading to disease development, due to the fascinating complexity of the host–pathogen interactions. There is accumulating data concerning the virulence factors associated with increased risk of disease, and the majority of these have pro-inflammatory activities. Despite this, only a small proportion of those infected with virulent strains develop disease. Several H. pylori virulence factors have multiple effects on different cell types, including the induction of pro- and anti-inflammatory, immune stimulatory, and immune modulatory responses. The expression of multiple virulence factors is also often linked, making it difficult to assess the meaning of their effects in isolation. Overall, H. pylori is thought to usually modulate inflammation and limit acute damage to the mucosa, enabling the bacteria to persist. If this delicate balance is disturbed, disease may then develop.},
  language     = {en},
  keywords     = {/unread,gastric cancer,Helicobacter pylori,inflammation,mucosal immunity,peptic ulcer disease},
  annotation   = {titleTranslation: 幽门螺旋杆菌感染的不同炎症反应：病因和临床结果\\
                  abstractTranslation: 细菌病原体幽门螺旋杆菌通常在幼儿时期定植于人类胃粘膜，并终生存在。 幽门螺杆菌已进化出多种机制来逃避免疫系统的清除，尽管会诱发胃部炎症，但大多数感染是无症状的。 幽门螺杆菌是消化性溃疡病和胃癌的主要病因。 然而，疾病的结果与胃黏膜慢性炎症的模式和严重程度有关，而慢性炎症又受到细菌和宿主因素的影响。 尽管经过了 20 多年的深入研究，但由于宿主与病原体之间的相互作用非常复杂，人们对导致疾病发生的情况仍然缺乏全面的了解。 有关增加患病风险的毒力因子的数据不断积累，其中大多数都具有促炎活性。 尽管如此，只有一小部分感染毒性菌株的患者会发病。 几种幽门螺杆菌毒力因子对不同类型的细胞有多重影响，包括诱导促炎和抗炎、免疫刺激和免疫调节反应。 多种毒力因子的表达通常也是相互关联的，因此很难单独评估其作用的意义。 总的来说，幽门螺杆菌通常被认为可以调节炎症，限制对粘膜的急性损伤，使细菌得以存活。 如果这种微妙的平衡受到破坏，就会引发疾病。\\
                  TLDR: Overall, H. pylori is thought to usually modulate inflammation and limit acute damage to the mucosa, enabling the bacteria to persist, and if this delicate balance is disturbed, disease may then develop.},
  file         = {C:\Users\liuli\Zotero\storage\3JMSYYG4\White 等 - 2015 - Differential inflammatory response to Helicobacter pylori infection etiology and clinical outcomes.pdf}
}

@article{whitesideMicrobiomeUrinaryTract2015,
  title        = {The Microbiome of the Urinary Tract—a Role beyond Infection},
  author       = {Whiteside, Samantha A. and Razvi, Hassan and Dave, Sumit and Reid, Gregor and Burton, Jeremy P.},
  date         = {2015-02},
  journaltitle = {Nature Reviews Urology},
  shortjournal = {Nat. Rev. Urol.},
  volume       = {12},
  number       = {2},
  pages        = {81--90},
  issn         = {1759-4812, 1759-4820},
  doi          = {10.1038/nrurol.2014.361},
  url          = {https://www.nature.com/articles/nrurol.2014.361},
  urldate      = {2024-11-27},
  abstract     = {Urologists rarely need to consider bacteria beyond their role in infectious disease. However, emerging evidence shows that the microorganisms inhabiting many sites of the body, including the urinary tract—which has long been assumed sterile in healthy individuals—might have a role in maintaining urinary health. Studies of the urinary microbiota have identified remarkable differences between healthy populations and those with urologic diseases. Microorganisms at sites distal to the kidney, bladder and urethra are likely to have a profound effect on urologic health, both positive and negative, owing to their metabolic output and other contributions. Connections between the gut microbiota and renal stone formation have already been discovered. In addition, bacteria are also used in the prevention of bladder cancer recurrence. In the future, urologists will need to consider possible influences of the microbiome in diagnosis and treatment of certain urological conditions. New insights might provide an opportunity to predict the risk of developing certain urological diseases and could enable the development of innovative therapeutic strategies.},
  language     = {en},
  annotation   = {abstractTranslation: 泌尿科医生很少需要考虑细菌在传染病中的作用之外的其他作用。然而，新出现的证据表明，栖息在包括泌尿道在内的人体许多部位的微生物可能在维持泌尿系统健康方面发挥着作用。对泌尿系统微生物群的研究发现，健康人群与泌尿系统疾病患者之间存在显著差异。肾脏、膀胱和尿道远端部位的微生物可能会对泌尿系统的健康产生深远的影响，无论是正面还是负面影响，这是因为它们的代谢输出和其他贡献。肠道微生物群与肾结石形成之间的联系已经被发现。此外，细菌还被用于预防膀胱癌复发。未来，泌尿科医生需要考虑微生物组在诊断和治疗某些泌尿科疾病时可能产生的影响。新的认识可能为预测罹患某些泌尿系统疾病的风险提供机会，并有助于开发创新的治疗策略。\\
                  titleTranslation: 尿路微生物群--感染之外的作用\\
                  TLDR: Urologists will need to consider possible influences of the microbiome in diagnosis and treatment of certain urological conditions, and new insights might provide an opportunity to predict the risk of developing certain urologogical diseases and could enable the development of innovative therapeutic strategies.},
  file         = {C:\Users\liuli\Zotero\storage\VWVVI6SC\Whiteside 等 - 2015 - The microbiome of the urinary tract—a role beyond infection.pdf}
}

@article{wiehagenFoxp4DispensableCell2012,
  title        = {Foxp4 Is Dispensable for {{T}} Cell Development, but Required for Robust Recall Responses},
  author       = {Wiehagen, Karla R. and Corbo-Rodgers, Evann and Li, Shanru and Staub, Elizabeth S. and Hunter, Christopher A. and Morrisey, Edward E. and Maltzman, Jonathan S.},
  date         = {2012},
  journaltitle = {PLOS One},
  shortjournal = {PLOS One},
  volume       = {7},
  number       = {8},
  eprint       = {22912696},
  eprinttype   = {pubmed},
  pages        = {e42273},
  issn         = {1932-6203},
  doi          = {10.1371/journal.pone.0042273},
  abstract     = {Transcription factors regulate T cell fates at every stage of development and differentiation. Members of the Foxp family of forkhead transcription factors are essential for normal T lineage development; Foxp3 is required for T regulatory cell generation and function, and Foxp1 is necessary for generation and maintenance of naïve T cells. Foxp4, an additional member of the Foxp family, is highly homologous to Foxp1 and has been shown to dimerize with other Foxp proteins. We report the initial characterization of Foxp4 in T lymphocytes. Foxp4 is expressed in both thymocytes and peripheral CD4(+) and CD8(+) T cells. We used a CD4Cre mediated approach to evaluate the cell autonomous role for Foxp4 in murine T lymphocytes. T cell development, peripheral cellularity and cell surface phenotype are normal in the absence of Foxp4. Furthermore, Foxp3(+) T regulatory cells develop normally in Foxp4 deficient animals and naïve Foxp4 deficient CD4 T cells can differentiate to inducible T regulatory cells in vitro. In wild-type T cells, expression of Foxp4 increases following activation, but deletion of Foxp4 does not affect T cell proliferative responses or in vitro effector T cell differentiation. In vivo, despite effective control of Toxoplasma gondii and acute lymphocytic choriomeningitis virus infections, effector cytokine production during antigen specific recall responses are reduced in the absence of Foxp4. We conclude that Foxp4 is dispensable for T cell development, but necessary for normal T cell cytokine recall responses to antigen following pathogenic infection.},
  language     = {en},
  pmcid        = {PMC3418275},
  keywords     = {/unread,Animals,Biomarkers,Cell Proliferation,Cytokines,Forkhead Transcription Factors,Gene Deletion,Homeostasis,Lymphocytic choriomeningitis virus,Mice,T-Lymphocyte Subsets,T-Lymphocytes,Thymocytes,Toxoplasma,Up-Regulation},
  annotation   = {titleTranslation: Foxp4对T细胞发育并非必需，但对强有力的记忆反应是必需的。\\
                  abstractTranslation: 转录因子在T细胞的每一个发展和分化阶段调节T细胞的命运。Foxp转录因子家族的成员对于正常T谱系的发展至关重要；Foxp3是T调节细胞生成和功能所必需的，而Foxp1则对于幼稚T细胞的生成和维持是必需的。Foxp家族的另一个成员Foxp4与Foxp1高度同源，已显示与其他Foxp蛋白形成二聚体。我们报告了Foxp4在T淋巴细胞中的初步特征分析。Foxp4在胸腺细胞和外周CD4(+)及CD8(+) T细胞中均有表达。我们使用CD4Cre介导的方法评估Foxp4在小鼠T淋巴细胞中的细胞自主作用。缺乏Foxp4时，T细胞发育、外周细胞量和细胞表面表型均正常。此外，Foxp4缺陷动物中的Foxp3(+) T调节细胞均正常发展，缺乏Foxp4的幼稚CD4 T细胞能够在体外分化为可诱导T调节细胞。在野生型T细胞中，Foxp4的表达在激活后增加，但删除Foxp4并不影响T细胞的增殖反应或体外效应T细胞分化。在体内，尽管有效控制了弓形虫和急性淋巴细胞性脉络膜脑炎病毒感染，缺乏Foxp4时抗原特异性召回反应中的效应细胞因子产生却减少。我们得出结论，Foxp4对T细胞发育是非必需的，但对于病原感染后正常的T细胞细胞因子召回反应则是必需的。\\
                  TLDR: It is concluded that Foxp4 is dispensable for T cell development, but necessary for normal T cell cytokine recall responses to antigen following pathogenic infection.},
  file         = {C:\Users\liuli\Zotero\storage\UCRC2WQJ\Wiehagen 等 - 2012 - Foxp4 is dispensable for T cell development, but required for robust recall responses.pdf}
}

@article{wong-rolleUnexpectedGuestsTumor2021,
  title        = {Unexpected Guests in the Tumor Microenvironment: Microbiome in Cancer},
  shorttitle   = {Unexpected Guests in the Tumor Microenvironment},
  author       = {Wong-Rolle, Abigail and Wei, Haohan Karen and Zhao, Chen and Jin, Chengcheng},
  date         = {2021-05},
  journaltitle = {Protein \& Cell},
  shortjournal = {Protein Cell},
  volume       = {12},
  number       = {5},
  pages        = {426--435},
  issn         = {1674-800X, 1674-8018},
  doi          = {10.1007/s13238-020-00813-8},
  url          = {https://academic.oup.com/proteincell/article/12/5/426/6724515},
  urldate      = {2024-11-25},
  abstract     = {Although intestinal microbiome have been established as an important biomarker and regulator of cancer development and therapeutic response, less is known about the role of microbiome at other body sites in cancer. Emerging evidence has revealed that the local microbiota make up an important part of the tumor microenvironment across many types of cancer, especially in cancers arising from mucosal sites, including the lung, skin and gastrointestinal tract. The populations of bacteria that reside specifically within tumors have been found to be tumor-type specific, and mechanistic studies have demonstrated that tumor-associated microbiota may directly regulate cancer initiation, progression and responses to chemo- or immuno-therapies. This review aims to provide a comprehensive review of the important literature on the microbiota in the cancerous tissue, and their function and mechanism of action in cancer development and treatment.},
  language     = {en},
  annotation   = {titleTranslation: 肿瘤微环境中的不速之客：癌症中的微生物群\\
                  TLDR: A comprehensive review of the important literature on the microbiota in the cancerous tissue, and their function and mechanism of action in cancer development and treatment is provided.},
  file         = {C:\Users\liuli\Zotero\storage\8K46CEFF\Wong-Rolle 等 - 2021 - Unexpected guests in the tumor microenvironment microbiome in cancer.pdf}
}

@article{wuMicrobiologicalCompositionFollicular2023,
  title        = {Microbiological Composition of Follicular Fluid in Patients Undergoing {{IVF}} and Its Association with Infertility},
  author       = {Wu, Yue-Rong and Dong, Yong-Hong and Liu, Chen-Jian and Tang, Xiao-Dan and Zhang, Ning-Nan and Shen, Jie and Wu, Ze and Li, Xiao-Ran and Shao, Jing-Yi},
  date         = {2023},
  journaltitle = {American Journal of Reproductive Immunology},
  volume       = {89},
  number       = {3},
  pages        = {e13652},
  issn         = {1600-0897},
  doi          = {10.1111/aji.13652},
  url          = {https://onlinelibrary.wiley.com/doi/abs/10.1111/aji.13652},
  urldate      = {2025-03-03},
  abstract     = {Problem In recent years, the incidence of female infertility has risen sharply, which is affected by many factors. It was recognized that female reproductive tract microbes play a role in the process of female conception. If the reproductive tract microbes could solve a certain proportion of infertility, it would certainly reduce the pain and economic burden of many patients. The objective of this study was to investigate the microbial community composition of follicular fluid in infertile patients and its potential impact on infertility. Method of study Follicular fluid from 49 primary infertility and 52 secondary infertility patients was collected by a negative pressure needle, and the microbiota was analyzed by 16S rDNA sequencing. Results It was found that Lactobacillus, especially L. crispatus, might have a positive effect on female pregnancy. Considering the presence or absence of male factors and different body mass indices, L. iners might inhibit female pregnancy. However, L. iners seemed to play a positive role in egg maturation, while Gardnerella and Cutibacterium acnes might have a negative effect on female pregnancy. Conclusions This study suggested the potential role of Lactobacillus in follicular fluid in improving female infertility and provided a theoretical basis for the future microbiological treatment of female infertility.},
  language     = {en},
  keywords     = {follicular fluid,in vitro fertilization,infertility,microbiota},
  annotation   = {TLDR: The objective of this study was to investigate the microbial community composition of follicular fluid in infertile patients and its potential impact on infertility.},
